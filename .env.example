# =============================================================================
# PhxNorth Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=PhxNorth Backend
VERSION=0.1.0
ENVIRONMENT=development          # development | production | testing
DEBUG=false
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# -----------------------------------------------------------------------------
# Database (PostgreSQL + asyncpg)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/phxnorth

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=["localhost:9092"]

# -----------------------------------------------------------------------------
# S3 (CV / document storage)
# -----------------------------------------------------------------------------
S3_BUCKET=phxnorth-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Webhook Dispatcher
# -----------------------------------------------------------------------------
WEBHOOK_TIMEOUT=10               # seconds
WEBHOOK_MAX_RETRIES=5

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_PREFIX=/api/v1
